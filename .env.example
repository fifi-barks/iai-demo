# IAI demo — environment configuration
# Copy to `.env` and fill in. NEVER commit your real .env (it is gitignored).
#   cp .env.example .env
# Load it into your shell before running:
#   set -a && source .env && set +a

# ─── Intent LLM (the agent's reasoning layer) ──────────────────────────────
# Which provider parses and reasons about the plain-language intent.
#   groq | cerebras | openai | ollama | none
# Default if unset: groq when GROQ_API_KEY is present, else ollama.
IAI_LLM_PROVIDER=groq

# Groq — free, no credit card: https://console.groq.com/keys
# The key lives ONLY here / in the environment — never in source.
GROQ_API_KEY=

# Optional: override the model. Default for groq is llama-3.3-70b-versatile.
# Other valid Groq IDs: llama-3.1-8b-instant, qwen/qwen3-32b, openai/gpt-oss-120b
# IAI_LLM_MODEL=llama-3.3-70b-versatile

# Alternative providers (only the selected provider's key is needed):
# CEREBRAS_API_KEY=
# OPENAI_API_KEY=

# Local fallback (used when IAI_LLM_PROVIDER=ollama):
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=phi

# ─── Cost gate ─────────────────────────────────────────────────────────────
# Infracost API key (free): https://www.infracost.io/docs/
INFRACOST_API_KEY=

# ─── Telegram interface (optional — the CLI needs none) ────────────────────
# Bot token from @BotFather. Only required to run `python -m bot.telegram_bot`.
TELEGRAM_BOT_TOKEN=

# ─── Paths / fixtures (sensible defaults; override only if needed) ──────────
# IAI_MANIFEST=manifest.yaml
#
# The cost gate runs Infracost LIVE by default (it prices what was generated,
# so it needs a valid INFRACOST_API_KEY above). Set this to a saved Infracost
# JSON file ONLY to run offline — tests, CI, or any run where you want a
# deterministic number and no network call. Leave it unset for real estimates.
# IAI_INFRACOST_FIXTURE=tests/fixtures/infracost_app_tier_pass.json

# ─── Security remediation (optional) ───────────────────────────────────────
# When the security gate flags SSH open to 0.0.0.0/0, the agent narrows the
# ingress to this CIDR (a private range by default) and re-scans to confirm.
# IAI_SSH_ALLOWED_CIDR=10.0.0.0/8

# ─── Cloud credentials: NONE GO HERE ───────────────────────────────────────
# AWS and GCP are keyless by design. On the demo VM, AWS resolves via the EC2
# instance role (IMDSv2) and GCP via Workload Identity Federation. There are no
# static cloud keys in this project. Confirm they resolve at runtime with:
#   aws sts get-caller-identity
#   gcloud auth application-default print-access-token
